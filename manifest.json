{
  "name": "Commander Companion",
  "short_name": "Companion",
  "description": "Remote control companion app for BYD Auto Commander",
  "start_url": "/app/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#111b23",
  "theme_color": "#1F8AFF",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/app/share.html",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
